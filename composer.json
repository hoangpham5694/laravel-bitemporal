{
  "name": "hoangphamdev/laravel-bitemporal",
  "description": "Laravel package for bitemporal Eloquent models",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/hoangpham5694/laravel-bitemporal",
  "keywords": [
    "laravel",
    "eloquent",
    "bitemporal",
    "temporal",
    "versioning",
    "package"
  ],
  "authors": [
    {
      "name": "Hoang Pham",
      "email": "hoangpham5694@gmail.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/database": "^9.0",
    "illuminate/support": "^9.0"
  },
  "autoload": {
    "psr-4": {
      "HoangPhamDev\\Bitemporal\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "HoangPhamDev\\Bitemporal\\Tests\\": "tests/"
    }
  },

  "extra": {
    "laravel": {
      "providers": [
        "HoangPhamDev\\Bitemporal\\PackageServiceProvider"
      ]
    }
  },
  "support": {
    "issues": "https://github.com/hoangpham5694/laravel-bitemporal/issues",
    "source": "https://github.com/hoangpham5694/laravel-bitemporal"
  },
  "require-dev": {
    "orchestra/testbench": "^7.0",
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "*"
  }
}
